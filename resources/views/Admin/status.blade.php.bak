<script>
$(document).ready(function() {
    // Handle delete results form submission
    $('#processDeleteBtn').click(function() {
        if (!$('#confirmDelete').is(':checked')) {
            alert('Please confirm that you understand this action cannot be undone.');
            return false;
        }

        const resultCodesText = $('#resultCodes').val().trim();
        if (!resultCodesText) {
            alert('Please enter at least one result code.');
            return false;
        }

        // Parse result codes (support both comma-separated and newline-separated)
        let resultCodes = resultCodesText.split(/[\n,]+/).map(code => code.trim()).filter(Boolean);
        
        if (resultCodes.length === 0) {
            alert('No valid result codes found.');
            return false;
        }

        // Show progress UI
        $('#deleteProgress').show();
        $('#processDeleteBtn').prop('disabled', true);
        
        // Initialize progress
        const total = resultCodes.length;
        let processed = 0;
        let successCount = 0;
        let failedCount = 0;
        let failedCodes = [];
        
        // Process deletion in batches to avoid timeout
        const batchSize = 5;
        let currentIndex = 0;
        
        function processBatch() {
            const batch = resultCodes.slice(currentIndex, currentIndex + batchSize);
            if (batch.length === 0) {
                // All batches processed
                let resultMessage = `Processed ${processed} results (${successCount} deleted, ${failedCount} failed).`;
                if (failedCount > 0) {
                    resultMessage += ' Failed codes: ' + failedCodes.join(', ');
                }
                $('#deleteDetails').html('<div class="alert ' + (failedCount > 0 ? 'alert-warning' : 'alert-success') + '">' + resultMessage + '</div>');
                $('#processDeleteBtn').prop('disabled', false);
                return;
            }
            
            // Process current batch
            const batchPromises = batch.map(code => {
                return $.ajax({
                    url: '/delete-result',
                    type: 'POST',
                    data: {
                        _token: '{{ csrf_token() }}',
                        code: code
                    },
                    dataType: 'json'
                });
            });
            
            // Wait for all requests in batch to complete
            $.when.apply($, batchPromises).then(function() {
                // Process each response in the batch
                for (let i = 0; i < arguments.length; i++) {
                    processed++;
                    const response = arguments[i][0]; // For single request
                    
                    if (response && response.success) {
                        successCount++;
                    } else {
                        failedCount++;
                        failedCodes.push(batch[i]);
                    }
                    
                    // Update progress
                    const progress = Math.floor((processed / total) * 100);
                    $('#deleteProgressBar').css('width', progress + '%').attr('aria-valuenow', progress);
                    $('#deleteStatus').text(`Processing: ${processed}/${total} (${progress}%)`);
                    
                    if (response && response.message) {
                        $('#deleteDetails').append(`<div>${batch[i]}: ${response.message}</div>`);
                    } else if (response && response.error) {
                        $('#deleteDetails').append(`<div class="text-danger">${batch[i]}: ${response.error}</div>`);
                    }
                    
                    // Auto-scroll to bottom of details
                    const detailsDiv = document.getElementById('deleteDetails');
                    detailsDiv.scrollTop = detailsDiv.scrollHeight;
                }
                
                // Process next batch
                currentIndex += batchSize;
                processBatch();
            }).fail(function(xhr, status, error) {
                // Handle batch failure
                for (let i = 0; i < batch.length; i++) {
                    processed++;
                    failedCount++;
                    failedCodes.push(batch[i]);
                    
                    const progress = Math.floor((processed / total) * 100);
                    $('#deleteProgressBar').css('width', progress + '%').attr('aria-valuenow', progress);
                    $('#deleteStatus').text(`Processing: ${processed}/${total} (${progress}%)`);
                    
                    let errorMsg = 'Unknown error';
                    if (xhr.responseJSON && xhr.responseJSON.error) {
                        errorMsg = xhr.responseJSON.error;
                    } else if (xhr.statusText) {
                        errorMsg = xhr.statusText;
                    }
                    
                    $('#deleteDetails').append(`<div class="text-danger">${batch[i]}: ${errorMsg}</div>`);
                }
                
                // Continue with next batch even if one fails
                currentIndex += batchSize;
                processBatch();
            });
        }
        
        // Start processing batches
        processBatch();
    });
    
    // Clear form when modal is closed
    $('#deleteResults').on('hidden.bs.modal', function () {
        $('#resultCodes').val('');
        $('#confirmDelete').prop('checked', false);
        $('#deleteProgress').hide();
        $('#deleteProgressBar').css('width', '0%').attr('aria-valuenow', 0);
        $('#deleteStatus').text('Processing: 0/0 (0%)');
        $('#deleteDetails').empty();
        $('#processDeleteBtn').prop('disabled', false);
    });
});
</script>

<!-- End of status.blade.php -->
